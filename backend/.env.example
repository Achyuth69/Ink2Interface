# Choose backend: groq | local
MODEL_BACKEND=groq

# ── Groq (default, no GPU needed) ────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# Vision model — llama-4-scout supports image inputs
# Other options: llama-4-maverick-17b-128e-instruct
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── Local model tiers (MODEL_BACKEND=local) ───────────────────────────────────
# Fast   — Qwen2-VL-2B (~6GB VRAM)
INK2INTERFACE_FAST_PATH=Qwen/Qwen2-VL-2B-Instruct

# Balanced — Qwen2-VL-7B (~16GB VRAM)
INK2INTERFACE_BALANCED_PATH=Qwen/Qwen2-VL-7B-Instruct

# Pro    — Qwen2-VL-72B (~80GB VRAM, multi-GPU)
INK2INTERFACE_PRO_PATH=Qwen/Qwen2-VL-72B-Instruct
